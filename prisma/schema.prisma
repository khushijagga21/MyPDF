generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  passwordHash String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  files        StoredFile[]
  history      FileHistory[]
}

model StoredFile {
  id           String        @id @default(uuid())
  userId       String?
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  originalName String
  storedName   String
  mimeType     String
  size         Int
  category     String
  /// "upload" = source file the user provided; "output" = processed result
  role         String        @default("upload")
  data         Bytes?
  createdAt    DateTime      @default(now())
  inputHistory  FileHistory[] @relation("InputFile")
  outputHistory FileHistory[] @relation("OutputFile")

  @@index([userId])
  @@index([userId, role])
  @@index([createdAt])
}

model FileHistory {
  id                 String      @id @default(cuid())
  userId             String?
  user               User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  storedFileId       String?
  storedFile         StoredFile? @relation("InputFile", fields: [storedFileId], references: [id], onDelete: SetNull)
  outputStoredFileId String?
  outputStoredFile   StoredFile? @relation("OutputFile", fields: [outputStoredFileId], references: [id], onDelete: SetNull)
  tool               String
  inputFileIds       String      @default("[]")
  outputFileName     String?
  outputSize         Int?
  status             String      @default("completed")
  errorMessage       String?
  createdAt          DateTime    @default(now())

  @@index([userId, createdAt])
}
